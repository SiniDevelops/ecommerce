{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/img/(.*)", "dest": "/img/$1" },
    { "src": "/fonts/(.*)", "dest": "/fonts/$1" },
    { "src": "/vendors/(.*)", "dest": "/vendors/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/contact", "dest": "/api/contact.php" },
    { "src": "/cart", "dest": "/api/cart.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
